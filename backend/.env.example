# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=True

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com

# Ingestion (required for scheduled job: ingestion.cron.run_ingestion_job)
INGESTION_DEFAULT_COMPANY_ID=1
# Linux/macOS: after deploy, run: python manage.py crontab add
INGESTION_KEYWORDS=Mobilis,Algérie Télécom,internet Algeria
INGESTION_RSS_FEEDS=https://feeds.bbci.co.uk/news/technology/rss.xml
# When true (default), RSS items must match at least one INGESTION_KEYWORDS substring
INGESTION_RSS_FILTER_BY_KEYWORDS=true

# Source toggles (true/false)
GOOGLE_NEWS_ENABLED=true
REDDIT_ENABLED=true
HACKERNEWS_ENABLED=true

YOUTUBE_API_KEY=
TWITTER_BEARER_TOKEN=
# Optional Twitter fallback (not official API; off by default). Requires: pip install snscrape
ENABLE_TWITTER_SCRAPER=false
INGESTION_TWITTER_SCRAPER_MAX=20

INGESTION_GDELT_MAX_RECORDS=15
INGESTION_YOUTUBE_MAX_VIDEOS=5
INGESTION_YOUTUBE_MAX_COMMENTS=50
INGESTION_TWITTER_MAX_RESULTS=10
INGESTION_REDDIT_LIMIT=25
INGESTION_HACKERNEWS_HITS=20
